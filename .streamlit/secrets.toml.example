# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# O arquivo secrets.toml NÃO deve ser commitado no git (já está no .gitignore).

# --- Autenticação ---
# Usuário de acesso ao app
AUTH_USERNAME = "admin"

# Hash SHA-256 da sua senha.
# Para gerar, execute no terminal:
#   python -c "import hashlib; print(hashlib.sha256('sua_senha'.encode()).hexdigest())"
AUTH_PASSWORD_HASH = "cole_o_hash_aqui"

# --- ScraperAPI (opcional, necessário para deploy em nuvem) ---
# Obtenha sua chave em https://www.scraperapi.com
# SCRAPERAPI_KEY = "sua_chave_aqui"
