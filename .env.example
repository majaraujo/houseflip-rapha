# Database
HOUSEFLIP_DB_PATH=data/houseflip.duckdb

# Scraper settings
SCRAPER_REQUEST_DELAY_SECONDS=1.5
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# ScraperAPI (opcional — necessário para deploy em nuvem)
# Obtenha sua chave em https://www.scraperapi.com
# SCRAPERAPI_KEY=sua_chave_aqui
